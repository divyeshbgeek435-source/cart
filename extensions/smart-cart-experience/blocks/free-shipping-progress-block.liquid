<div class="sce-free-shipping-widget" {{ block.shopify_attributes }}>
  <div class="sce-free-shipping-widget__title">{{ block.settings.widget_title }}</div>
  <div class="sce-free-shipping-widget__message">{{ block.settings.placeholder_message }}</div>
  <div class="sce-free-shipping-widget__bar">
    <div class="sce-free-shipping-widget__bar-fill" style="width: 0%;"></div>
  </div>
  <div class="sce-free-shipping-widget__hint"></div>
</div>

{{ 'free-shipping-progress.css' | asset_url | stylesheet_tag }}
<script
  src="{{ 'free-shipping-progress.js' | asset_url }}"
  data-threshold="{{ block.settings.free_shipping_threshold }}"
  data-shipping-charge="{{ block.settings.shipping_charge_amount }}"
  data-title="{{ block.settings.widget_title | escape }}"
  data-progress-text="{{ block.settings.progress_message | escape }}"
  data-reached-text="{{ block.settings.reached_message | escape }}"
  data-cart-name="{{ block.settings.cart_name_text | escape }}"
  data-name-targets=".sce-free-shipping-widget"
  data-targets=".sce-free-shipping-widget"
  data-log-url="{{ shop.secure_url }}/apps/sce/cart-access"
  data-log-enabled="{% if block.settings.enable_cart_access_log %}true{% else %}false{% endif %}"
  defer
></script>

{% schema %}
{
  "name": "Shipping Progress",
  "target": "section",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "Free shipping threshold ($)",
      "default": 200
    },
    {
      "type": "number",
      "id": "shipping_charge_amount",
      "label": "Estimated shipping charge",
      "default": 10
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Widget title",
      "default": "Free shipping progress"
    },
    {
      "type": "text",
      "id": "progress_message",
      "label": "Progress message",
      "default": "Add [remaining_amount] more for free shipping on orders [threshold] or more."
    },
    {
      "type": "text",
      "id": "reached_message",
      "label": "Reached message",
      "default": "You unlocked free shipping!"
    },
    {
      "type": "text",
      "id": "placeholder_message",
      "label": "Placeholder text",
      "default": "Live cart message appears here after page load."
    },
    {
      "type": "text",
      "id": "cart_name_text",
      "label": "Cart name text",
      "default": "d",
      "info": "Keep empty to hide name badge."
    },
    {
      "type": "checkbox",
      "id": "enable_cart_access_log",
      "label": "Log cart API reads (server + DB)",
      "default": true
    }
  ]
}
{% endschema %}
